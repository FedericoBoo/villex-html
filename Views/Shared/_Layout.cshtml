<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Villex</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@2.47.0/dist/tabler-icons.min.css" />
    <style>
            body {
                background-color: #0f172a;
                color: #f8fafc;
                font-family: 'Segoe UI', sans-serif;
            }

            .navbar-villex {
                background-color: #1e2d3b;
                border-bottom: 3px solid #6366f1;
            }

            .navbar-brand {
                color: #6366f1 !important;
                font-weight: 800;
                font-size: 1.4rem;
                letter-spacing: 2px;
            }

            .nav-link {
                color: #94a3b8 !important;
            }

                .nav-link:hover, .nav-link.active {
                    color: #f8fafc !important;
                }

            .btn-villex {
                background-color: #6366f1;
                border: none;
                color: white;
            }

                .btn-villex:hover {
                    background-color: #4f46e5;
                    color: white;
                }

            .card-villex {
                background-color: #1e293b;
                border: 1px solid #334155;
                border-radius: 12px;
            }

            .table-villex {
                color: #f8fafc;
            }

                .table-villex thead {
                    background-color: #6366f1;
                    color: white;
                }

                .table-villex tbody tr:hover {
                    background-color: #1e293b;
                }

            .form-control, .form-select {
                background-color: #334155;
                border-color: #475569;
                color: #f8fafc;
            }

                .form-control:focus, .form-select:focus {
                    background-color: #334155;
                    border-color: #6366f1;
                    color: #f8fafc;
                    box-shadow: 0 0 0 3px rgba(99,102,241,0.2);
                }

            .alert-success {
                background-color: #166534;
                border-color: #16a34a;
                color: #dcfce7;
            }

            .alert-danger {
                background-color: #7f1d1d;
                border-color: #ef4444;
                color: #fee2e2;
            }

            footer {
                color: #475569;
                font-size: 0.8rem;
            }

            .fab-btn {
                position: fixed;
                bottom: 2rem;
                right: 2rem;
                width: 52px;
                height: 52px;
                border-radius: 50%;
                background: linear-gradient(135deg, #6366f1, #8b5cf6);
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.3rem;
                text-decoration: none;
                box-shadow: 0 4px 20px rgba(99,102,241,0.5);
                transition: transform 0.2s, box-shadow 0.2s;
                z-index: 999;
            }

                .fab-btn:hover {
                    transform: scale(1.1);
                    box-shadow: 0 6px 24px rgba(99,102,241,0.65);
                    color: white;
                }
    </style>
</head>
<body>
    @if (Context.Session.GetString("Usuario") != null)
    {
        <nav class="navbar navbar-expand-lg navbar-villex px-4">
            <a class="navbar-brand" href="/">VILLEX</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Roles" ? "active" : "")"
                           href="/Roles">
                            <i class="ti ti-shield"></i> Roles
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuarios" ? "active" : "")"
                           href="/Usuarios">
                            <i class="ti ti-users"></i> Usuarios
                        </a>
                    </li>
                </ul>
                <span class="text-secondary me-3">
                    <i class="ti ti-user"></i> @Context.Session.GetString("Usuario")
                </span>
                <a href="/Login/Logout" class="btn btn-sm btn-outline-danger">
                    <i class="ti ti-logout"></i> Salir
                </a>
            </div>
        </nav>

        <a href="/Usuarios/Crear" class="fab-btn" title="Nuevo usuario">
            <i class="ti ti-user-plus"></i>
        </a>
    }

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="text-center py-3">
        © 2026 Villex — Todos los derechos reservados.
    </footer>
</body>
</html>
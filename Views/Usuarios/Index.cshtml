@using VillexMVC.Models
@model List<UsuarioViewModel>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="roles-header-full">
    <div class="roles-eyebrow">Gestión de accesos</div>
    <h2 class="roles-title-full">Usuarios del Sistema</h2>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert-villex alert-villex-success">
        <i class="ti ti-circle-check"></i> @TempData["Exito"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-villex alert-villex-danger">
        <i class="ti ti-alert-circle"></i> @TempData["Error"]
    </div>
}

<div class="toolbar-row">
    <div class="search-bar-wrap">
        <i class="ti ti-search search-icon"></i>
        <input type="text" id="buscarUsuario" class="search-input" placeholder="Buscar por nombre de usuario…" oninput="filtrarUsuarios()" />
    </div>
    <a asp-action="Crear" class="btn-nuevo-rol">
        <svg class="icon-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
        Nuevo usuario
    </a>
</div>

<p class="roles-subtitle">
    <span class="badge-count">@Model.Count</span>
    usuario@(Model.Count != 1 ? "s" : "") registrado@(Model.Count != 1 ? "s" : "")
</p>

<div class="tabla-wrap">
    <table class="tabla-roles" id="tablaUsuarios">
        <thead>
            <tr>
                <th class="col-id">ID</th>
                <th>Usuario</th>
                <th>Contraseña</th>
                <th class="col-acciones">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="empty-state">
                        <p>No hay usuarios registrados.</p>
                        <a asp-action="Crear" class="btn-nuevo-rol btn-sm-nuevo">Crear el primero</a>
                    </td>
                </tr>
            }
            @foreach (var u in Model)
            {
                <tr>
                    <td><span class="id-badge">#@u.Id</span></td>
                    <td>
                        <div class="rol-nombre">
                            <span class="rol-dot"></span>
                            @u.Username
                        </div>
                    </td>
                    <td class="rol-desc">••••••••</td>
                    <td>
                        <div class="acciones-wrap">
                            <a asp-action="Editar" asp-route-id="@u.Id" class="btn-accion btn-editar" title="Editar">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                </svg>
                            </a>
                            <form asp-action="Eliminar" asp-route-id="@u.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('¿Eliminar el usuario «@u.Username»?')">
                                <button type="submit" class="btn-accion btn-eliminar" title="Eliminar">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12" /></svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .roles-header-full {
        width: 100%;
        margin-bottom: 2rem;
        text-align: center;
        background: linear-gradient(135deg, #6366f1, #7c3aed);
        border-radius: 16px;
        padding: 2.5rem 1.5rem;
        box-shadow: 0 8px 24px rgba(99,102,241,0.3);
    }

    .roles-eyebrow {
        font-size: 0.8rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #e0e7ff;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .roles-title-full {
        font-size: 3rem;
        font-weight: 800;
        color: #ffffff !important;
        -webkit-text-fill-color: #ffffff;
        margin: 0;
        letter-spacing: -0.02em;
        text-shadow: 0 2px 12px rgba(0,0,0,0.25);
    }

    .alert-villex {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.9rem 1.2rem;
        border-radius: 10px;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
    }

    .alert-villex-success {
        background: #052e16;
        border: 1px solid #166534;
        color: #86efac;
    }

    .alert-villex-danger {
        background: #1c0a0a;
        border: 1px solid #7f1d1d;
        color: #fca5a5;
    }

    .toolbar-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0.75rem;
    }

    .search-bar-wrap {
        position: relative;
        flex: 1;
    }

    .search-icon {
        position: absolute;
        left: 1.1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #475569;
        font-size: 1.05rem;
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 10px;
        color: #f8fafc;
        padding: 0.85rem 1.2rem 0.85rem 2.9rem;
        font-size: 0.9rem;
        transition: border-color 0.15s, box-shadow 0.15s;
        outline: none;
        box-sizing: border-box;
    }

        .search-input::placeholder {
            color: #475569;
        }

        .search-input:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.18);
        }

    .btn-nuevo-rol {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 0.85rem 1.5rem;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
        white-space: nowrap;
        box-shadow: 0 4px 14px rgba(99,102,241,0.35);
        flex-shrink: 0;
    }

        .btn-nuevo-rol:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            color: white;
        }

    .btn-sm-nuevo {
        padding: 0.55rem 1.1rem;
        font-size: 0.85rem;
        margin-top: 0.85rem;
    }

    .icon-plus {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
    }

    .roles-subtitle {
        font-size: 0.9rem;
        color: #94a3b8;
        margin: 0 0 1.5rem 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .badge-count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white;
        font-size: 0.78rem;
        font-weight: 700;
        padding: 0.15rem 0.6rem;
        border-radius: 20px;
        min-width: 26px;
    }

    .tabla-wrap {
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 14px;
        overflow: hidden;
    }

    .tabla-roles {
        width: 100%;
        border-collapse: collapse;
    }

        .tabla-roles thead tr {
            background: #0f172a;
            border-bottom: 2px solid #6366f1;
        }

        .tabla-roles thead th {
            padding: 1.1rem 1.5rem;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #94a3b8;
        }

    .col-id {
        width: 90px;
    }

    .col-acciones {
        width: 110px;
        text-align: center;
    }

    .tabla-roles tbody tr {
        border-bottom: 1px solid #243044;
        transition: background 0.12s;
    }

        .tabla-roles tbody tr:last-child {
            border-bottom: none;
        }

        .tabla-roles tbody tr:hover {
            background: #243044;
        }

    .tabla-roles tbody td {
        padding: 1.25rem 1.5rem;
        font-size: 0.92rem;
        vertical-align: middle;
        color: #cbd5e1;
    }

    .id-badge {
        display: inline-block;
        background: #0f172a;
        border: 1px solid #334155;
        border-radius: 6px;
        padding: 0.25rem 0.6rem;
        font-size: 0.8rem;
        color: #64748b;
        font-family: monospace;
    }

    .rol-nombre {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        font-weight: 600;
        font-size: 0.92rem;
        color: #f1f5f9;
    }

    .rol-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #6366f1;
        flex-shrink: 0;
    }

    .rol-desc {
        color: #64748b;
        font-size: 0.88rem;
        letter-spacing: 0.06em;
    }

    .acciones-wrap {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
    }

    .btn-accion {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid #334155;
        background: #0f172a;
        cursor: pointer;
        transition: background 0.13s, border-color 0.13s, color 0.13s;
        text-decoration: none;
        color: #94a3b8;
    }

        .btn-accion svg {
            width: 16px;
            height: 16px;
            flex-shrink: 0;
        }

    .btn-editar:hover {
        background: rgba(99,102,241,0.15);
        border-color: #6366f1;
        color: #818cf8;
    }

    .btn-eliminar:hover {
        background: rgba(239,68,68,0.15);
        border-color: #ef4444;
        color: #f87171;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 1.5rem !important;
        color: #475569;
    }

        .empty-state p {
            margin-bottom: 0.4rem;
            font-size: 0.9rem;
        }

    .hidden-row {
        display: none;
    }
</style>

<script>
    function filtrarUsuarios() {
        const q = document.getElementById('buscarUsuario').value.toLowerCase();
        document.querySelectorAll('#tablaUsuarios tbody tr').forEach(tr => {
            const texto = tr.innerText.toLowerCase();
            tr.classList.toggle('hidden-row', q.length > 0 && !texto.includes(q));
        });
    }
</script>
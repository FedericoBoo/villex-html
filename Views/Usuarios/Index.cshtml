@using VillexMVC.Models
@model List<UsuarioViewModel>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="roles-header">
    <div>
        <div class="roles-eyebrow">Gestión de accesos</div>
        <h2 class="roles-title">Usuarios del Sistema</h2>
        <p class="roles-subtitle">
            <span class="badge-count">@Model.Count</span>
            usuario@(Model.Count != 1 ? "s" : "") registrado@(Model.Count != 1 ? "s" : "")
        </p>
    </div>
    <a asp-action="Crear" class="btn-nuevo-rol">
        <i class="ti ti-user-plus"></i> Nuevo usuario
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert-villex alert-villex-success">
        <i class="ti ti-circle-check"></i> @TempData["Exito"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-villex alert-villex-danger">
        <i class="ti ti-alert-circle"></i> @TempData["Error"]
    </div>
}

<div class="search-bar-wrap">
    <i class="ti ti-search search-icon"></i>
    <input type="text" id="buscarUsuario" class="search-input" placeholder="Buscar por nombre de usuario…" oninput="filtrarUsuarios()" />
</div>

<div class="tabla-wrap">
    <table class="tabla-roles" id="tablaUsuarios">
        <thead>
            <tr>
                <th class="col-id">ID</th>
                <th>Usuario</th>
                <th>Contraseña</th>
                <th class="col-acciones">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="empty-state">
                        <i class="ti ti-users empty-icon"></i>
                        <p>No hay usuarios registrados.</p>
                        <a asp-action="Crear" class="btn-nuevo-rol btn-sm-nuevo">Crear el primero</a>
                    </td>
                </tr>
            }
            @foreach (var u in Model)
            {
                <tr>
                    <td><span class="id-badge">#@u.Id</span></td>
                    <td>
                        <div class="rol-nombre">
                            <span class="rol-dot"></span>
                            @u.Username
                        </div>
                    </td>
                    <td class="rol-desc">••••••••</td>
                    <td>
                        <div class="acciones-wrap">
                            <form asp-action="Eliminar" asp-route-id="@u.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('¿Eliminar el usuario «@u.Username»?')">
                                <button type="submit" class="btn-accion btn-eliminar" title="Eliminar">
                                    <i class="ti ti-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .roles-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 1.25rem;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .roles-eyebrow {
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #6366f1;
        font-weight: 700;
        margin-bottom: 0.2rem;
    }

    .roles-title {
        font-size: 2.2rem;
        font-weight: 800;
        color: #000000 !important;
        -webkit-text-fill-color: #000000;
        margin: 0 0 0.3rem 0;
        letter-spacing: -0.02em;
    }

    .roles-subtitle {
        font-size: 0.82rem;
        color: #94a3b8;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .badge-count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white;
        font-size: 0.72rem;
        font-weight: 700;
        padding: 0.1rem 0.5rem;
        border-radius: 20px;
        min-width: 24px;
    }

    .btn-nuevo-rol {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 0.55rem 1.1rem;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
        white-space: nowrap;
        box-shadow: 0 4px 14px rgba(99,102,241,0.35);
    }

        .btn-nuevo-rol:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            color: white;
        }

    .btn-sm-nuevo {
        padding: 0.4rem 0.9rem;
        font-size: 0.78rem;
        margin-top: 0.6rem;
    }

    .alert-villex {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.65rem 1rem;
        border-radius: 10px;
        font-size: 0.85rem;
        margin-bottom: 1rem;
    }

    .alert-villex-success {
        background: #052e16;
        border: 1px solid #166534;
        color: #86efac;
    }

    .alert-villex-danger {
        background: #1c0a0a;
        border: 1px solid #7f1d1d;
        color: #fca5a5;
    }

    .search-bar-wrap {
        position: relative;
        margin-bottom: 1rem;
    }

    .search-icon {
        position: absolute;
        left: 0.9rem;
        top: 50%;
        transform: translateY(-50%);
        color: #475569;
        font-size: 0.95rem;
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 10px;
        color: #f8fafc;
        padding: 0.55rem 1rem 0.55rem 2.4rem;
        font-size: 0.85rem;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
        box-sizing: border-box;
    }

        .search-input::placeholder {
            color: #475569;
        }

        .search-input:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.18);
        }

    .tabla-wrap {
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 12px;
        overflow: hidden;
    }

    .tabla-roles {
        width: 100%;
        border-collapse: collapse;
    }

        .tabla-roles thead tr {
            background: #0f172a;
            border-bottom: 2px solid #6366f1;
        }

        .tabla-roles thead th {
            padding: 0.65rem 1rem;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.07em;
            text-transform: uppercase;
            color: #94a3b8;
        }

    .col-id {
        width: 60px;
    }

    .col-acciones {
        width: 80px;
        text-align: center;
    }

    .tabla-roles tbody tr {
        border-bottom: 1px solid #243044;
        transition: background 0.12s;
    }

        .tabla-roles tbody tr:last-child {
            border-bottom: none;
        }

        .tabla-roles tbody tr:hover {
            background: #243044;
        }

    .tabla-roles tbody td {
        padding: 0.45rem 1rem;
        font-size: 0.82rem;
        vertical-align: middle;
        color: #cbd5e1;
    }

    .id-badge {
        display: inline-block;
        background: #0f172a;
        border: 1px solid #334155;
        border-radius: 5px;
        padding: 0.1rem 0.4rem;
        font-size: 0.72rem;
        color: #64748b;
        font-family: monospace;
    }

    .rol-nombre {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        font-size: 0.82rem;
        color: #f1f5f9;
    }

    .rol-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #6366f1;
        flex-shrink: 0;
    }

    .rol-desc {
        color: #64748b;
        font-size: 0.8rem;
        letter-spacing: 0.05em;
    }

    .acciones-wrap {
        display: flex;
        justify-content: center;
        gap: 0.35rem;
    }

    .btn-accion {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 7px;
        border: 1px solid transparent;
        background: transparent;
        cursor: pointer;
        font-size: 0.85rem;
        transition: background 0.13s, border-color 0.13s, color 0.13s;
        text-decoration: none;
        color: #94a3b8;
    }

    .btn-eliminar:hover {
        background: rgba(239,68,68,0.12);
        border-color: #ef4444;
        color: #f87171;
    }

    .empty-state {
        text-align: center;
        padding: 2.5rem 1rem !important;
        color: #475569;
    }

    .empty-icon {
        font-size: 2rem;
        display: block;
        margin-bottom: 0.6rem;
        opacity: 0.4;
    }

    .empty-state p {
        margin-bottom: 0.2rem;
        font-size: 0.85rem;
    }

    .hidden-row {
        display: none;
    }
</style>

<script>
    function filtrarUsuarios() {
        const q = document.getElementById('buscarUsuario').value.toLowerCase();
        document.querySelectorAll('#tablaUsuarios tbody tr').forEach(tr => {
            const texto = tr.innerText.toLowerCase();
            tr.classList.toggle('hidden-row', q.length > 0 && !texto.includes(q));
        });
    }
</script>
@model Rol
@{ ViewData["Title"] = "Nuevo Rol"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card-villex p-4">
            <div class="mb-4">
                <h4 style="color:#6366f1; font-weight:700;"><i class="ti ti-shield-plus"></i> Nuevo Rol</h4>
                <small class="text-secondary">Completa los datos para crear un rol</small>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-3">
                    <i class="ti ti-alert-circle"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="Crear" method="post">
                <div class="mb-3">
                    <label class="form-label text-secondary">Nombre del rol</label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Administrador" />
                </div>
                <div class="mb-4">
                    <label class="form-label text-secondary">Descripcion</label>
                    <input asp-for="Descripcion" class="form-control" placeholder="Ej: Acceso total al sistema" />
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-villex flex-fill">
                        <i class="ti ti-check"></i> Guardar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                        <i class="ti ti-arrow-left"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@model LoginViewModel
@{
    Layout = null; ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Villex</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <style>
            body {
                background-color: #0f172a;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                font-family: 'Segoe UI', sans-serif;
            }

            .login-card {
                width: 390px;
                padding: 2.25rem 2rem;
                border-radius: 16px;
                border: 1px solid #334155;
                background-color: #1e293b;
                box-shadow: 0 4px 24px rgba(99,102,241,0.1);
            }

            .login-icon {
                width: 58px;
                height: 58px;
                background-color: #312e81;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 1.25rem;
            }

                .login-icon i {
                    font-size: 28px;
                    color: #818cf8;
                }

            .login-title {
                text-align: center;
                font-size: 20px;
                font-weight: 600;
                color: #f8fafc;
                margin-bottom: 0.2rem;
            }

            .login-sub {
                text-align: center;
                font-size: 13px;
                color: #64748b;
                margin-bottom: 1.75rem;
            }

            .form-label {
                font-size: 13px;
                font-weight: 500;
                color: #94a3b8;
            }

            .form-control {
                background-color: #334155;
                border-color: #475569;
                color: #f8fafc;
                border-radius: 8px;
                height: 42px;
            }

                .form-control:focus {
                    background-color: #334155;
                    border-color: #6366f1;
                    color: #f8fafc;
                    box-shadow: 0 0 0 3px rgba(99,102,241,0.2);
                }

            .btn-ingresar {
                background-color: #6366f1;
                border: none;
                border-radius: 8px;
                height: 44px;
                font-weight: 600;
                color: white;
                width: 100%;
            }

                .btn-ingresar:hover {
                    background-color: #4f46e5;
                    color: white;
                }

                .btn-ingresar:disabled {
                    background-color: #334155;
                    cursor: not-allowed;
                }

            footer {
                position: fixed;
                bottom: 10px;
                width: 100%;
                text-align: center;
                color: #334155;
                font-size: 12px;
            }

            .sesion-ok {
                width: 390px;
                margin-top: 1rem;
                padding: 0.7rem 1rem;
                border-radius: 10px;
                background: #052e16;
                border: 1px solid #166534;
                color: #86efac;
                font-size: 0.85rem;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

            .accesos-rapidos {
                width: 390px;
                margin-top: 1rem;
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 0.75rem;
            }

            .acceso-btn {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 0.5rem;
                padding: 1rem;
                border-radius: 12px;
                border: 1px solid #334155;
                background-color: #1e293b;
                color: #94a3b8;
                text-decoration: none;
                font-size: 0.8rem;
                font-weight: 600;
                transition: border-color 0.15s, color 0.15s, background 0.15s;
                cursor: pointer;
            }

                .acceso-btn i {
                    font-size: 1.5rem;
                }

                .acceso-btn:hover {
                    border-color: #6366f1;
                    color: #818cf8;
                    background: #1a1f35;
                }

                .acceso-btn span {
                    color: #64748b;
                    font-size: 0.72rem;
                    font-weight: 400;
                }

                .acceso-btn.bloqueado {
                    opacity: 0.4;
                    cursor: not-allowed;
                }

                    .acceso-btn.bloqueado:hover {
                        border-color: #334155;
                        color: #94a3b8;
                        background: #1e293b;
                    }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-icon"><i class="ti ti-shield-lock"></i></div>
        <p class="login-title">VILLEX</p>
        <p class="login-sub">Sistema de gestion empresarial</p>

        <form asp-controller="Login" asp-action="Index" method="post">
            <div class="mb-3">
                <label class="form-label"><i class="ti ti-user"></i> Usuario</label>
                <input asp-for="Username" class="form-control" placeholder="Ingresa tu usuario" />
            </div>
            <div class="mb-3">
                <label class="form-label"><i class="ti ti-lock"></i> Contrasena</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
            </div>
            <button type="submit" class="btn btn-ingresar mt-1">
                <i class="ti ti-login"></i> Ingresar
            </button>
        </form>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mt-3 d-flex align-items-center gap-2">
                <i class="ti ti-alert-circle"></i> @ViewBag.Error
            </div>
        }
    </div>

    @{
        var sesionActiva = Context.Session.GetString("Usuario") != null;
    }

    @if (sesionActiva)
    {
        <div class="sesion-ok">
            <i class="ti ti-circle-check"></i>
            Sesión activa como <strong>@Context.Session.GetString("Usuario")</strong>. Elegí a dónde ir:
        </div>
    }

    <div class="accesos-rapidos">
        @if (sesionActiva)
        {
            <a href="/Usuarios" class="acceso-btn">
                <i class="ti ti-users"></i>
                Gestión de Usuarios
                <span>Crear y administrar usuarios</span>
            </a>
            <a href="/Roles" class="acceso-btn">
                <i class="ti ti-shield"></i>
                Gestión de Roles
                <span>Crear y administrar roles</span>
            </a>
        }
        else
        {
            <div class="acceso-btn bloqueado" title="Iniciá sesión primero">
                <i class="ti ti-lock"></i>
                Gestión de Usuarios
                <span>Iniciá sesión para acceder</span>
            </div>
            <div class="acceso-btn bloqueado" title="Iniciá sesión primero">
                <i class="ti ti-lock"></i>
                Gestión de Roles
                <span>Iniciá sesión para acceder</span>
            </div>
        }
    </div>

    <footer>© 2026 Villex — Todos los derechos reservados.</footer>
</body>
</html>